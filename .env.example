# Server Configuration
SERVER_NAME=matrix.example.com

# Signing Key (set after first deployment to persist across deploys)
# Get this by running: railway run cat /data/homeserver.signing.key
# Format: ed25519 a_RXGa "base64_key_here"
SYNAPSE_SIGNING_KEY=

# Database Configuration
# Railway auto-provides these when you add PostgreSQL:
# PGUSER, PGPASSWORD, PGDATABASE, PGHOST, PGPORT
#
# For local development, set them manually:
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=railway
PGHOST=localhost
PGPORT=5432
